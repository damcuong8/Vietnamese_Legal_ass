LANGSMITH_TRACING=false
LANGSMITH_PROJECT=legal-rag

LLM_MODEL=qwen3.5-9b
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=EMPTY
LLM_MAX_TOKENS=65536
LLM_REASONING_FORMAT=deepseek

CHECKPOINTER_BACKEND=none

MAIN_LLM_ENABLE_THINKING=true
MAIN_LLM_TEMPERATURE=0.5
MAIN_LLM_TOP_P=0.9
MAIN_LLM_TOP_K=20
PLANNER_THINKING_TOKEN_BUDGET=1024
REASONING_THINKING_TOKEN_BUDGET=4096

COMPRESS_LLM_ENABLE_THINKING=true
COMPRESS_LLM_TEMPERATURE=0.3
COMPRESS_LLM_TOP_P=0.80
COMPRESS_LLM_TOP_K=20

EMBEDDING_MAX_CONCURRENT=1
RERANKER_MAX_CONCURRENT=1
VNCORENLP_MAX_CONCURRENT=8
RERANKER_BATCH_SIZE=64

# Optional NVIDIA endpoint for smoke/debug only.
NVIDIA_API_KEY=
NVIDIA_LLM_MODEL=qwen/qwen3.5-9b
NVIDIA_LLM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_LLM_MAX_TOKENS=8192
